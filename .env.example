# 獨立容器模式用設定
# 如果你是安裝 Home Assistant OS App，請改在 App options 內填寫，不用這個檔案。

# Telegram Bot 設定
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Home Assistant / HomePod Mini 通知
# Home Assistant OS App 會自動使用 Supervisor 內部 API，不需要手動填這兩個。
HA_BASE_URL=http://homeassistant.local:8123
HA_TOKEN=your_home_assistant_long_lived_access_token
HA_NOTIFY_MODE=webhook
HA_TTS_TARGET=garbage_truck_eta

# Eupfin / 樂圾通 API
EUPFIN_BASE_URL=https://customer-tw.eupfin.com/Eup_Servlet_Nuser_SOAP/Eup_Servlet_Nuser_SOAP

# 目標路線設定
TARGET_CUST_ID=5005808
TARGET_ROUTE_ID=461
TARGET_POINT_SEQ=27
TARGET_POINT_NAME=有謙家園
TARGET_DAYS=MON,TUE,WED,THU,FRI,SAT
ALERT_OFFSETS=10,3

# 資料收集與預測
COLLECTION_START=19:00
COLLECTION_END=21:30
HISTORY_WEEKS=8
ARRIVAL_RADIUS_METERS=80
MATCH_RADIUS_METERS=250
MIN_HISTORY_RUNS=3
PROGRESS_WINDOW_METERS=150
LATERAL_OFFSET_LIMIT_METERS=80
BACKTRACK_TOLERANCE_METERS=30
AMBIGUOUS_SEGMENT_EPSILON_METERS=15

# 本機執行 / 容器設定
STATE_FILE=data/state.json
DATABASE_FILE=data/history.db
CHECK_INTERVAL=1m
SEND_TEST_MESSAGE_ON_START=false
PORT=8080
